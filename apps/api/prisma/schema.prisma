// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  engineer
  company
  admin
}

enum ProficiencyLevel {
  beginner
  intermediate
  advanced
  expert
}

model User {
  id              String    @id @default(uuid()) @db.Uuid
  clerkId         String    @unique
  email           String    @unique
  role            UserRole
  isEmailVerified Boolean   @default(false)
  createdAt       DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt       DateTime  @updatedAt @db.Timestamptz(3)

  engineerProfile EngineerProfile?
  companyProfile  CompanyProfile?
  refreshTokens   RefreshToken[]
  assessments     Assessment[]
  tasks           Task[]
  taskParticipations TaskParticipation[]
  taskSubmissions TaskSubmission[]
  taskQuestions   TaskQuestion[]
  taskNdaSignatures TaskNDASignature[]
  products        Product[]
  purchases       Purchase[]
  
  // Module 6: Hiring & Contracts
  jobPostings     JobPosting[]
  jobApplications JobApplication[]
  companyContracts Contract[] @relation("CompanyContracts")
  engineerContracts Contract[] @relation("EngineerContracts")
  sentMessageRequests MessageRequest[] @relation("SentMessageRequests")
  receivedMessageRequests MessageRequest[] @relation("ReceivedMessageRequests")
  conversationsAsParticipant1 Conversation[] @relation("ConversationsAsParticipant1")
  conversationsAsParticipant2 Conversation[] @relation("ConversationsAsParticipant2")
  messages        Message[]
  projectChatParticipants ProjectChatParticipant[]
  projectChatMessages ProjectChatMessage[]
  offPlatformViolations OffPlatformViolation[]
  
  // Module 7: Payments, Escrow & GST
  payments        Payment[]
  payouts         Payout[]
  wallet          Wallet?
  kycVerification KYCVerification?
  subscriptions   PlatformSubscription[]
  
  // Module 8: Security & Compliance
  userConsents    UserConsent[]
  accountDeletionRequests AccountDeletionRequest[]
  privacyPolicyAcceptances PrivacyPolicyAcceptance[]

  @@index([email])
  @@index([clerkId])
  @@map("users")
}

model EngineerProfile {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @unique @db.Uuid
  fullName          String
  bio               String?  @db.Text
  location          String?
  githubUrl         String?
  linkedinUrl       String?
  portfolioUrl      String?
  yearsOfExperience Int?
  hourlyRate        Decimal? @db.Decimal(10, 2)
  minHourlyRate     Decimal? @db.Decimal(10, 2)
  maxHourlyRate     Decimal? @db.Decimal(10, 2)
  upiId             String?
  kycVerified       Boolean  @default(false)
  
  // Availability
  availabilityStatus String  @default("available_now") // available_now | available_in_weeks | not_available
  availableInWeeks   Int?
  
  // NeuronScore
  neuronScore       Int      @default(0)
  neuronTier        String   @default("conditional") // elite | professional | verified | conditional
  lastActivityAt    DateTime @default(now()) @db.Timestamptz(3)
  
  // Profile completeness
  completenessScore Int      @default(0)
  
  // Profile builder steps
  basicInfoComplete     Boolean @default(false)
  skillsComplete        Boolean @default(false)
  experienceComplete    Boolean @default(false)
  projectsComplete      Boolean @default(false)
  pricingComplete       Boolean @default(false)
  paymentComplete       Boolean @default(false)
  kycComplete           Boolean @default(false)
  
  createdAt         DateTime @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime @updatedAt @db.Timestamptz(3)

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills    EngineerSkill[]
  projects  EngineerProject[]
  experiences EngineerExperience[]
  activities BuildInPublicActivity[]
  assessments Assessment[]
  neuronScoreHistory NeuronScoreHistory[]
  miniGateTests MiniGateTest[]
  taskParticipations TaskParticipation[]
  taskSubmissions TaskSubmission[]
  taskNdaSignatures TaskNDASignature[]
  products  Product[]
  
  // Module 6: Hiring & Contracts
  jobApplications JobApplication[]
  smartMatches SmartMatch[]
  contracts   Contract[]
  timeEntries TimeEntry[]
  availabilitySlots AvailabilitySlot[]
  analytics   EngineerAnalytics[]
  bundles     Bundle[]

  @@index([userId])
  @@index([availabilityStatus])
  @@index([neuronScore])
  @@index([neuronTier])
  @@index([completenessScore])
  @@index([hourlyRate])
  @@index([location])
  @@index([lastActivityAt])
  @@map("engineer_profiles")
}

model CompanyProfile {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @unique @db.Uuid
  companyName String
  description String?  @db.Text
  website     String?
  logoUrl     String?
  location    String?
  size        String?
  industry    String?
  foundedYear Int?
  gstNumber   String?
  
  // Trust and verification
  trustScore       Int     @default(0)
  websiteVerified  Boolean @default(false)
  gstVerified      Boolean @default(false)
  
  // Hiring status
  isHiring         Boolean @default(false)
  hiringIntents    String[] // full_time, freelance, project, bounty
  aiRequirements   String[] // chatbots, automation, agents, data, vision, nlp, mlops
  
  createdAt   DateTime @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks Task[]
  purchases Purchase[]
  
  // Module 6: Hiring & Contracts
  jobPostings JobPosting[]
  contracts   Contract[]
  analytics   CompanyAnalytics[]

  @@index([userId])
  @@index([isHiring])
  @@index([trustScore])
  @@index([industry])
  @@map("company_profiles")
}

model EngineerSkill {
  id                 String           @id @default(uuid()) @db.Uuid
  engineerProfileId  String           @db.Uuid
  skillName          String
  proficiencyLevel   ProficiencyLevel
  yearsOfExperience  Int?
  projectCount       Int              @default(0)
  verified           Boolean          @default(false)
  createdAt          DateTime         @default(now()) @db.Timestamptz(3)
  updatedAt          DateTime         @updatedAt @db.Timestamptz(3)

  engineerProfile EngineerProfile @relation(fields: [engineerProfileId], references: [id], onDelete: Cascade)

  @@index([engineerProfileId])
  @@index([skillName])
  @@index([proficiencyLevel])
  @@map("engineer_skills")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  token     String   @unique
  expiresAt DateTime @db.Timestamptz(3)
  createdAt DateTime @default(now()) @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model OTPAttempt {
  id        String   @id @default(uuid()) @db.Uuid
  email     String
  attempts  Int      @default(1)
  expiresAt DateTime @db.Timestamptz(3)
  createdAt DateTime @default(now()) @db.Timestamptz(3)

  @@index([email, expiresAt])
  @@map("otp_attempts")
}

model EngineerProject {
  id                String   @id @default(uuid()) @db.Uuid
  engineerProfileId String   @db.Uuid
  title             String
  description       String   @db.Text
  problemSolved     String   @db.Text
  techStack         Json     // Array of technologies
  demoUrl           String?
  githubUrl         String?
  screenshots       String[] // Array of S3 URLs
  performanceMetrics Json?   // Custom metrics object
  aiModelUsed       String?
  architectureType  String?
  featured          Boolean  @default(false)
  displayOrder      Int      @default(0)
  createdAt         DateTime @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime @updatedAt @db.Timestamptz(3)

  engineerProfile EngineerProfile @relation(fields: [engineerProfileId], references: [id], onDelete: Cascade)

  @@index([engineerProfileId])
  @@index([featured])
  @@map("engineer_projects")
}

model EngineerExperience {
  id                String   @id @default(uuid()) @db.Uuid
  engineerProfileId String   @db.Uuid
  title             String
  company           String
  location          String?
  startDate         DateTime @db.Timestamptz(3)
  endDate           DateTime? @db.Timestamptz(3)
  current           Boolean  @default(false)
  description       String   @db.Text
  achievements      String[] // Array of achievement strings
  createdAt         DateTime @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime @updatedAt @db.Timestamptz(3)

  engineerProfile EngineerProfile @relation(fields: [engineerProfileId], references: [id], onDelete: Cascade)

  @@index([engineerProfileId])
  @@map("engineer_experiences")
}

model BuildInPublicActivity {
  id                String   @id @default(uuid()) @db.Uuid
  engineerProfileId String   @db.Uuid
  content           String   @db.Text
  createdAt         DateTime @default(now()) @db.Timestamptz(3)

  engineerProfile EngineerProfile @relation(fields: [engineerProfileId], references: [id], onDelete: Cascade)

  @@index([engineerProfileId])
  @@index([createdAt])
  @@map("build_in_public_activities")
}

// Module 3: Assessment & NeuronScore Models
model Assessment {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @db.Uuid
  engineerProfileId String   @db.Uuid
  
  // Assessment metadata
  sessionId         String   @unique
  sessionToken      String?  @unique
  skillsAssessed    String[] // Array of skills
  experienceLevel   String   // junior, mid, senior, expert
  
  // Questions
  mcqQuestions      Json     // Array of MCQ questions
  codingTasks       Json     // Array of coding tasks
  caseScenario      Json?    // Case scenario question
  
  // Responses
  mcqResponses      Json?    // User's MCQ answers
  codingSubmissions Json?    // Code submissions
  caseResponse      String?  @db.Text
  
  // Scoring
  mcqScore          Int?     // 0-100
  codingScore       Int?     // 0-100
  caseScore         Int?     // 0-100
  overallScore      Int?     // 0-100
  
  // Dimension scores (0-100 each)
  modelKnowledge    Int?
  engineeringDepth  Int?
  systemDesign      Int?
  codingQuality     Int?
  practicalApp      Int?
  communication     Int?
  
  // Tier assignment
  tier              String?  // elite, professional, verified, conditional, rejected
  
  // Proctoring
  proctoringEvents  Json?    // Array of proctoring events
  tabSwitches       Int      @default(0)
  focusLosses       Int      @default(0)
  pasteAttempts     Int      @default(0)
  flagged           Boolean  @default(false)
  autoSubmitted     Boolean  @default(false)
  proctoringViolation Boolean @default(false)
  
  // Code evaluation
  plagiarismScore   Float?   // 0-1 similarity score
  plagiarismFlagged Boolean  @default(false)
  
  // Report
  reportUrl         String?  // S3 URL of PDF report
  reportGenerated   Boolean  @default(false)
  skillGapAnalysis  Json?    // AI-generated analysis
  improvementRoadmap Json?   // AI-generated roadmap
  
  // Status
  status            String   @default("in_progress") // in_progress, submitted, evaluated
  startedAt         DateTime @default(now()) @db.Timestamptz(3)
  submittedAt       DateTime? @db.Timestamptz(3)
  evaluatedAt       DateTime? @db.Timestamptz(3)
  
  // Device fingerprint
  ipAddress         String?
  deviceFingerprint String?
  
  createdAt         DateTime @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime @updatedAt @db.Timestamptz(3)

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  engineerProfile EngineerProfile  @relation(fields: [engineerProfileId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([engineerProfileId])
  @@index([sessionId])
  @@index([status])
  @@index([tier])
  @@map("assessments")
}

model NeuronScoreHistory {
  id                String   @id @default(uuid()) @db.Uuid
  engineerProfileId String   @db.Uuid
  
  previousScore     Int
  newScore          Int
  scoreDelta        Int
  reason            String   @db.Text
  dimension         String?  // Which dimension changed
  triggeredBy       String?  // system, user, admin
  
  // Score breakdown at this point
  assessment        Int?
  clientRatings     Int?
  portfolioDepth    Int?
  workDelivery      Int?
  marketplace       Int?
  community         Int?
  
  createdAt         DateTime @default(now()) @db.Timestamptz(3)

  engineerProfile EngineerProfile @relation(fields: [engineerProfileId], references: [id], onDelete: Cascade)

  @@index([engineerProfileId])
  @@index([createdAt])
  @@map("neuron_score_history")
}

model MiniGateTest {
  id                String   @id @default(uuid()) @db.Uuid
  engineerProfileId String   @db.Uuid
  taskId            String?  @db.Uuid // Optional: if for specific task
  
  domain            String   // Specific skill domain
  questions         Json     // 15-min test questions
  responses         Json?    // User responses
  score             Int?     // 0-100
  passed            Boolean  @default(false)
  
  startedAt         DateTime @default(now()) @db.Timestamptz(3)
  submittedAt       DateTime? @db.Timestamptz(3)
  
  createdAt         DateTime @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime @updatedAt @db.Timestamptz(3)

  engineerProfile EngineerProfile @relation(fields: [engineerProfileId], references: [id], onDelete: Cascade)

  @@index([engineerProfileId])
  @@index([taskId])
  @@map("mini_gate_tests")
}

// Module 4: Task & Bounty System Models
enum TaskType {
  bounty
  direct
  contest
}

enum TaskStatus {
  draft
  pending_escrow
  open
  in_progress
  in_review
  completed
  cancelled
}

enum TaskDifficulty {
  easy
  medium
  hard
  expert
}

enum PaymentType {
  fixed
  hourly
  milestone
}

enum SubmissionStatus {
  pending
  under_review
  accepted
  rejected
  winner
}

model Task {
  id                String         @id @default(uuid()) @db.Uuid
  companyProfileId  String         @db.Uuid
  userId            String         @db.Uuid
  
  // Basic info
  title             String
  type              TaskType
  category          String[]       // Multi-select categories
  problemStatement  String         @db.Text
  currentState      String?        @db.Text
  expectedOutcome   String         @db.Text
  deliverables      Json           // JSONB array of deliverable items
  techRequirements  String[]       // Array of tech/skills
  
  // Timeline & Reward
  timeline          Int            // Days
  deadline          DateTime?      @db.Timestamptz(3)
  rewardAmount      Decimal        @db.Decimal(12, 2)
  paymentType       PaymentType
  currency          String         @default("INR")
  
  // Selection & Requirements
  selectionCriteria Json           // JSONB criteria
  minNeuronScore    Int            @default(0)
  ndaRequired       Boolean        @default(false)
  difficulty        TaskDifficulty
  
  // Status & Escrow
  status            TaskStatus     @default(draft)
  escrowDeposited   Boolean        @default(false)
  escrowId          String?        // Razorpay escrow ID
  escrowAmount      Decimal?       @db.Decimal(12, 2)
  paymentId         String?        // Razorpay payment ID
  
  // AI Enrichment
  aiEnriched        Boolean        @default(false)
  estimatedTimeline Int?           // AI suggested timeline
  suggestedReward   Json?          // {min, max, currency}
  vagueDeliverables String[]       // Flagged vague items
  recommendedType   TaskType?
  autoTaggedSkills  String[]
  postingQuality    Int?           // 1-10 rating
  aiSuggestions     Json?          // Additional AI insights
  
  // Contest specific
  isContest         Boolean        @default(false)
  contestRanks      Json?          // [{rank: 1, percentage: 50}, {rank: 2, percentage: 30}, ...]
  maxWinners        Int?
  
  // Metadata
  viewCount         Int            @default(0)
  participantCount  Int            @default(0)
  submissionCount   Int            @default(0)
  
  publishedAt       DateTime?      @db.Timestamptz(3)
  completedAt       DateTime?      @db.Timestamptz(3)
  createdAt         DateTime       @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime       @updatedAt @db.Timestamptz(3)

  companyProfile    CompanyProfile @relation(fields: [companyProfileId], references: [id], onDelete: Cascade)
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  participations    TaskParticipation[]
  submissions       TaskSubmission[]
  questions         TaskQuestion[]
  ndaSignatures     TaskNDASignature[]

  @@index([companyProfileId])
  @@index([userId])
  @@index([status])
  @@index([type])
  @@index([difficulty])
  @@index([minNeuronScore])
  @@index([publishedAt])
  @@index([deadline])
  @@map("tasks")
}

model TaskParticipation {
  id                String   @id @default(uuid()) @db.Uuid
  taskId            String   @db.Uuid
  engineerProfileId String   @db.Uuid
  userId            String   @db.Uuid
  
  // Participation details
  approach          String   @db.Text
  estimatedTime     Int?     // Days
  proposedRate      Decimal? @db.Decimal(10, 2)
  
  // Status
  approved          Boolean  @default(false)
  rejected          Boolean  @default(false)
  rejectionReason   String?  @db.Text
  
  createdAt         DateTime @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime @updatedAt @db.Timestamptz(3)

  task              Task             @relation(fields: [taskId], references: [id], onDelete: Cascade)
  engineerProfile   EngineerProfile  @relation(fields: [engineerProfileId], references: [id], onDelete: Cascade)
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, engineerProfileId])
  @@index([taskId])
  @@index([engineerProfileId])
  @@map("task_participations")
}

model TaskSubmission {
  id                String           @id @default(uuid()) @db.Uuid
  taskId            String           @db.Uuid
  engineerProfileId String           @db.Uuid
  userId            String           @db.Uuid
  
  // Submission content
  description       String           @db.Text
  demoUrl           String?
  githubUrl         String?
  codeUrl           String?
  screenshots       String[]         // S3 URLs
  videoUrl          String?
  performanceMetrics Json?           // JSONB metrics
  architectureDiagram String?        // S3 URL
  
  // Evaluation
  status            SubmissionStatus @default(pending)
  score             Int?             // 0-100
  feedback          String?          @db.Text
  criteriaScores    Json?            // Scores per criterion
  
  // Winner info
  isWinner          Boolean          @default(false)
  rank              Int?             // For contests
  payoutAmount      Decimal?         @db.Decimal(12, 2)
  payoutStatus      String?          // pending, processing, completed, failed
  payoutId          String?          // Razorpay payout ID
  paidAt            DateTime?        @db.Timestamptz(3)
  
  submittedAt       DateTime         @default(now()) @db.Timestamptz(3)
  reviewedAt        DateTime?        @db.Timestamptz(3)
  createdAt         DateTime         @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime         @updatedAt @db.Timestamptz(3)

  task              Task             @relation(fields: [taskId], references: [id], onDelete: Cascade)
  engineerProfile   EngineerProfile  @relation(fields: [engineerProfileId], references: [id], onDelete: Cascade)
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([engineerProfileId])
  @@index([status])
  @@index([isWinner])
  @@map("task_submissions")
}

model TaskQuestion {
  id                String   @id @default(uuid()) @db.Uuid
  taskId            String   @db.Uuid
  userId            String   @db.Uuid
  
  question          String   @db.Text
  answer            String?  @db.Text
  answeredBy        String?  @db.Uuid // User ID of answerer
  answeredAt        DateTime? @db.Timestamptz(3)
  
  isPublic          Boolean  @default(true)
  
  createdAt         DateTime @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime @updatedAt @db.Timestamptz(3)

  task              Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([userId])
  @@map("task_questions")
}

model TaskNDASignature {
  id                String   @id @default(uuid()) @db.Uuid
  taskId            String   @db.Uuid
  engineerProfileId String   @db.Uuid
  userId            String   @db.Uuid
  
  ndaPdfUrl         String   // S3 URL of generated NDA
  signedPdfUrl      String?  // S3 URL of signed NDA
  signature         String?  // Digital signature data
  ipAddress         String
  
  signed            Boolean  @default(false)
  signedAt          DateTime? @db.Timestamptz(3)
  
  createdAt         DateTime @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime @updatedAt @db.Timestamptz(3)

  task              Task             @relation(fields: [taskId], references: [id], onDelete: Cascade)
  engineerProfile   EngineerProfile  @relation(fields: [engineerProfileId], references: [id], onDelete: Cascade)
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, engineerProfileId])
  @@index([taskId])
  @@index([engineerProfileId])
  @@map("task_nda_signatures")
}

// Module 5: AI Marketplace Models

enum ProductCategory {
  ai_agents
  fine_tuned_models
  saas_tools
  automation_workflows
  datasets_prompts
  apis_microservices
}

enum PricingModel {
  one_time
  subscription
  freemium
  per_call
}

enum ProductStatus {
  draft
  pending_moderation
  published
  suspended
  archived
}

enum PurchaseStatus {
  pending
  completed
  failed
  refunded
  disputed
}

enum DisputeStatus {
  open
  under_review
  resolved_buyer
  resolved_seller
  closed
}

enum SubscriptionStatus {
  active
  past_due
  cancelled
  expired
}

model Product {
  id                String          @id @default(uuid()) @db.Uuid
  engineerProfileId String          @db.Uuid
  userId            String          @db.Uuid
  
  name              String
  slug              String          @unique
  tagline           String
  category          ProductCategory
  tags              String[]
  thumbnailUrl      String
  description       String          @db.Text
  demoUrl           String
  screenshots       String[]
  
  techStack         Json
  aiModelUsed       String?
  architectureType  String?
  
  pricingModel      PricingModel
  priceINR          Decimal?        @db.Decimal(12, 2)
  priceUSD          Decimal?        @db.Decimal(12, 2)
  features          Json
  
  performanceMetrics Json?
  deliveryType      String
  customizationAvailable Boolean    @default(false)
  supportType       String?
  supportDuration   String?
  
  currentVersion    String          @default("1.0.0")
  versionHistory    Json?
  
  status            ProductStatus   @default(draft)
  moderationStatus  String?
  moderationNotes   String?         @db.Text
  moderatedAt       DateTime?       @db.Timestamptz(3)
  
  viewCount         Int             @default(0)
  purchaseCount     Int             @default(0)
  rating            Decimal?        @db.Decimal(3, 2)
  reviewCount       Int             @default(0)
  
  publishedAt       DateTime?       @db.Timestamptz(3)
  createdAt         DateTime        @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime        @updatedAt @db.Timestamptz(3)

  engineerProfile   EngineerProfile @relation(fields: [engineerProfileId], references: [id], onDelete: Cascade)
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  purchases         Purchase[]
  reviews           ProductReview[]
  bundles           BundleProduct[]
  analytics         ProductAnalytics[]
  referralLinks     ReferralLink[]

  @@index([engineerProfileId])
  @@index([userId])
  @@index([category])
  @@index([status])
  @@index([slug])
  @@index([publishedAt])
  @@index([rating])
  @@map("products")
}

model Purchase {
  id                String         @id @default(uuid()) @db.Uuid
  productId         String         @db.Uuid
  buyerId           String         @db.Uuid
  companyProfileId  String?        @db.Uuid
  
  priceINR          Decimal        @db.Decimal(12, 2)
  priceUSD          Decimal?       @db.Decimal(12, 2)
  currency          String         @default("INR")
  
  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpaySignature String?
  paymentMethod     String?
  
  licenseKey        String         @unique
  licenseActive     Boolean        @default(true)
  licenseRevokedAt  DateTime?      @db.Timestamptz(3)
  
  accessGranted     Boolean        @default(false)
  accessDetails     Json?
  
  status            PurchaseStatus @default(pending)
  
  platformCommission Decimal?      @db.Decimal(12, 2)
  engineerPayout    Decimal?       @db.Decimal(12, 2)
  payoutStatus      String?
  payoutId          String?
  paidOutAt         DateTime?      @db.Timestamptz(3)
  
  referralCode      String?
  referralCommission Decimal?      @db.Decimal(12, 2)
  
  disputeEligible   Boolean        @default(true)
  disputeDeadline   DateTime       @db.Timestamptz(3)
  
  purchasedAt       DateTime       @default(now()) @db.Timestamptz(3)
  createdAt         DateTime       @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime       @updatedAt @db.Timestamptz(3)

  product           Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  buyer             User           @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  companyProfile    CompanyProfile? @relation(fields: [companyProfileId], references: [id], onDelete: SetNull)
  
  dispute           Dispute?
  subscription      Subscription?

  @@index([productId])
  @@index([buyerId])
  @@index([companyProfileId])
  @@index([licenseKey])
  @@index([status])
  @@index([referralCode])
  @@map("purchases")
}

model Subscription {
  id                String             @id @default(uuid()) @db.Uuid
  purchaseId        String             @unique @db.Uuid
  productId         String             @db.Uuid
  buyerId           String             @db.Uuid
  
  razorpaySubscriptionId String?       @unique
  razorpayPlanId    String?
  
  billingCycle      String
  nextBillingDate   DateTime           @db.Timestamptz(3)
  lastBillingDate   DateTime?          @db.Timestamptz(3)
  
  status            SubscriptionStatus @default(active)
  failedPayments    Int                @default(0)
  
  cancelledAt       DateTime?          @db.Timestamptz(3)
  cancellationReason String?           @db.Text
  
  createdAt         DateTime           @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime           @updatedAt @db.Timestamptz(3)

  purchase          Purchase           @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([buyerId])
  @@index([status])
  @@index([nextBillingDate])
  @@map("subscriptions")
}

model Dispute {
  id                String         @id @default(uuid()) @db.Uuid
  purchaseId        String         @unique @db.Uuid
  productId         String         @db.Uuid
  buyerId           String         @db.Uuid
  sellerId          String         @db.Uuid
  
  reason            String         @db.Text
  evidence          Json?
  
  status            DisputeStatus  @default(open)
  resolution        String?        @db.Text
  resolvedBy        String?        @db.Uuid
  resolvedAt        DateTime?      @db.Timestamptz(3)
  
  refundAmount      Decimal?       @db.Decimal(12, 2)
  refundProcessed   Boolean        @default(false)
  refundId          String?
  
  createdAt         DateTime       @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime       @updatedAt @db.Timestamptz(3)

  purchase          Purchase       @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
  @@map("disputes")
}

model ProductReview {
  id                String   @id @default(uuid()) @db.Uuid
  productId         String   @db.Uuid
  purchaseId        String   @db.Uuid
  buyerId           String   @db.Uuid
  
  rating            Int
  title             String?
  review            String   @db.Text
  pros              String[]
  cons              String[]
  
  verified          Boolean  @default(true)
  helpfulCount      Int      @default(0)
  
  createdAt         DateTime @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime @updatedAt @db.Timestamptz(3)

  product           Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([purchaseId])
  @@index([productId])
  @@index([buyerId])
  @@index([rating])
  @@map("product_reviews")
}

model Bundle {
  id                String          @id @default(uuid()) @db.Uuid
  engineerProfileId String          @db.Uuid
  userId            String          @db.Uuid
  
  name              String
  description       String          @db.Text
  thumbnailUrl      String?
  
  originalPrice     Decimal         @db.Decimal(12, 2)
  bundlePrice       Decimal         @db.Decimal(12, 2)
  discountPercent   Decimal         @db.Decimal(5, 2)
  currency          String          @default("INR")
  
  active            Boolean         @default(true)
  
  createdAt         DateTime        @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime        @updatedAt @db.Timestamptz(3)

  products          BundleProduct[]
  engineerProfile   EngineerProfile @relation(fields: [engineerProfileId], references: [id], onDelete: Cascade)

  @@index([engineerProfileId])
  @@index([userId])
  @@index([active])
  @@map("bundles")
}

model BundleProduct {
  id                String   @id @default(uuid()) @db.Uuid
  bundleId          String   @db.Uuid
  productId         String   @db.Uuid
  
  displayOrder      Int      @default(0)
  
  createdAt         DateTime @default(now()) @db.Timestamptz(3)

  bundle            Bundle   @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  product           Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([bundleId, productId])
  @@index([bundleId])
  @@index([productId])
  @@map("bundle_products")
}

model ReferralLink {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @db.Uuid
  productId         String?  @db.Uuid
  
  referralCode      String   @unique
  
  clickCount        Int      @default(0)
  purchaseCount     Int      @default(0)
  totalCommission   Decimal  @default(0) @db.Decimal(12, 2)
  
  active            Boolean  @default(true)
  
  createdAt         DateTime @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime @updatedAt @db.Timestamptz(3)

  product           Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([productId])
  @@index([referralCode])
  @@map("referral_links")
}

model ProductAnalytics {
  id                String   @id @default(uuid()) @db.Uuid
  productId         String   @db.Uuid
  
  date              DateTime @db.Date
  
  views             Int      @default(0)
  purchases         Int      @default(0)
  revenue           Decimal  @default(0) @db.Decimal(12, 2)
  refunds           Int      @default(0)
  
  topIndustries     Json?
  
  createdAt         DateTime @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime @updatedAt @db.Timestamptz(3)

  product           Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, date])
  @@index([productId])
  @@index([date])
  @@map("product_analytics")
}
// Module 6: Hiring & Contracts Schema

enum HiringMode {
  full_time
  internship
  hourly_contract
  project_contract
}

enum ContractStatus {
  draft
  pending_signature
  active
  completed
  terminated
  amended
  disputed
}

enum MilestoneStatus {
  pending
  in_progress
  submitted
  approved
  paid
}

enum MessageRequestStatus {
  pending
  approved
  declined
}

enum OffPlatformViolationLevel {
  warning
  review
  suspended
}

model JobPosting {
  id                String   @id @default(uuid()) @db.Uuid
  companyProfileId  String   @db.Uuid
  userId            String   @db.Uuid
  
  title             String
  description       String   @db.Text
  hiringMode        HiringMode
  
  // Requirements
  requiredSkills    String[]
  experienceLevel   String   // junior, mid, senior, expert
  
  // Compensation
  budgetMin         Decimal? @db.Decimal(12, 2)
  budgetMax         Decimal? @db.Decimal(12, 2)
  currency          String   @default("INR")
  
  // Full-time specific
  ctcMin            Decimal? @db.Decimal(12, 2)
  ctcMax            Decimal? @db.Decimal(12, 2)
  
  // Internship specific
  duration          Int?     // months
  stipend           Decimal? @db.Decimal(12, 2)
  
  // Hourly specific
  estimatedHours    Int?
  isTimeBoxed       Boolean  @default(false)
  endDate           DateTime? @db.Timestamptz(3)
  
  // Project specific
  projectScope      String?  @db.Text
  milestones        Json?    // Array of milestone definitions
  
  // Location & Remote
  location          String?
  isRemote          Boolean  @default(true)
  
  // Status
  status            String   @default("open") // open, closed, filled
  viewCount         Int      @default(0)
  applicationCount  Int      @default(0)
  
  postedAt          DateTime @default(now()) @db.Timestamptz(3)
  closedAt          DateTime? @db.Timestamptz(3)
  createdAt         DateTime @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime @updatedAt @db.Timestamptz(3)

  companyProfile    CompanyProfile @relation(fields: [companyProfileId], references: [id], onDelete: Cascade)
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  applications      JobApplication[]
  smartMatches      SmartMatch[]
  contracts         Contract[]

  @@index([companyProfileId])
  @@index([userId])
  @@index([hiringMode])
  @@index([status])
  @@index([postedAt])
  @@map("job_postings")
}

model JobApplication {
  id                String   @id @default(uuid()) @db.Uuid
  jobPostingId      String   @db.Uuid
  engineerProfileId String   @db.Uuid
  userId            String   @db.Uuid
  
  coverLetter       String   @db.Text
  proposedRate      Decimal? @db.Decimal(12, 2)
  availability      String?  // immediate, 2_weeks, 1_month
  
  status            String   @default("pending") // pending, shortlisted, rejected, accepted
  
  appliedAt         DateTime @default(now()) @db.Timestamptz(3)
  reviewedAt        DateTime? @db.Timestamptz(3)
  createdAt         DateTime @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime @updatedAt @db.Timestamptz(3)

  jobPosting        JobPosting      @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)
  engineerProfile   EngineerProfile @relation(fields: [engineerProfileId], references: [id], onDelete: Cascade)
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([jobPostingId])
  @@index([engineerProfileId])
  @@index([status])
  @@map("job_applications")
}

model SmartMatch {
  id                String   @id @default(uuid()) @db.Uuid
  jobPostingId      String   @db.Uuid
  engineerProfileId String   @db.Uuid
  
  skillMatchScore   Decimal  @db.Decimal(5, 2) // 0-100
  budgetFit         Boolean  @default(false)
  availabilityFit   Boolean  @default(false)
  
  matchDetails      Json     // Detailed breakdown
  
  invited           Boolean  @default(false)
  invitedAt         DateTime? @db.Timestamptz(3)
  
  createdAt         DateTime @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime @updatedAt @db.Timestamptz(3)

  jobPosting        JobPosting      @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)
  engineerProfile   EngineerProfile @relation(fields: [engineerProfileId], references: [id], onDelete: Cascade)

  @@unique([jobPostingId, engineerProfileId])
  @@index([jobPostingId])
  @@index([engineerProfileId])
  @@index([skillMatchScore])
  @@map("smart_matches")
}

model Contract {
  id                String         @id @default(uuid()) @db.Uuid
  jobPostingId      String?        @db.Uuid
  companyProfileId  String         @db.Uuid
  engineerProfileId String         @db.Uuid
  companyUserId     String         @db.Uuid
  engineerUserId    String         @db.Uuid
  
  hiringMode        HiringMode
  
  // Contract details
  title             String
  scope             String         @db.Text
  startDate         DateTime       @db.Timestamptz(3)
  endDate           DateTime?      @db.Timestamptz(3)
  
  // Compensation
  rate              Decimal        @db.Decimal(12, 2)
  currency          String         @default("INR")
  
  // Full-time specific
  ctc               Decimal?       @db.Decimal(12, 2)
  placementFee      Decimal?       @db.Decimal(12, 2)
  placementFeePaid  Boolean        @default(false)
  
  // Internship specific
  stipendAmount     Decimal?       @db.Decimal(12, 2)
  durationMonths    Int?
  
  // Hourly specific
  hourlyRate        Decimal?       @db.Decimal(10, 2)
  estimatedHours    Int?
  walletBalance     Decimal?       @db.Decimal(12, 2)
  
  // Project specific
  totalAmount       Decimal?       @db.Decimal(12, 2)
  milestones        Json?          // Array of milestones
  
  // Legal terms
  ipOwnership       String         @default("company") // company, engineer, shared
  ndaRequired       Boolean        @default(true)
  confidentialityTerms String?     @db.Text
  
  // Trial engagement
  trialMode         Boolean        @default(false)
  trialCompleted    Boolean        @default(false)
  trialExtended     Boolean        @default(false)
  
  // Signing
  status            ContractStatus @default(draft)
  contractPdfUrl    String?        // Pre-filled contract
  
  companySigned     Boolean        @default(false)
  companySignature  String?        @db.Text
  companySignedAt   DateTime?      @db.Timestamptz(3)
  companySignIp     String?
  
  engineerSigned    Boolean        @default(false)
  engineerSignature String?        @db.Text
  engineerSignedAt  DateTime?      @db.Timestamptz(3)
  engineerSignIp    String?
  
  finalContractUrl  String?        // Fully signed contract
  
  // Amendment tracking
  amendmentCount    Int            @default(0)
  lastAmendedAt     DateTime?      @db.Timestamptz(3)
  
  activatedAt       DateTime?      @db.Timestamptz(3)
  completedAt       DateTime?      @db.Timestamptz(3)
  terminatedAt      DateTime?      @db.Timestamptz(3)
  terminationReason String?        @db.Text
  
  createdAt         DateTime       @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime       @updatedAt @db.Timestamptz(3)

  jobPosting        JobPosting?     @relation(fields: [jobPostingId], references: [id], onDelete: SetNull)
  companyProfile    CompanyProfile  @relation(fields: [companyProfileId], references: [id], onDelete: Cascade)
  engineerProfile   EngineerProfile @relation(fields: [engineerProfileId], references: [id], onDelete: Cascade)
  companyUser       User            @relation("CompanyContracts", fields: [companyUserId], references: [id], onDelete: Cascade)
  engineerUser      User            @relation("EngineerContracts", fields: [engineerUserId], references: [id], onDelete: Cascade)
  
  timeEntries       TimeEntry[]
  milestonePayments MilestonePayment[]
  amendments        ContractAmendment[]
  projectRoom       ProjectChatRoom?
  disputes          ContractDispute[]

  @@index([companyProfileId])
  @@index([engineerProfileId])
  @@index([hiringMode])
  @@index([status])
  @@index([startDate])
  @@map("contracts")
}

model TimeEntry {
  id                String   @id @default(uuid()) @db.Uuid
  contractId        String   @db.Uuid
  engineerProfileId String   @db.Uuid
  
  date              DateTime @db.Date
  hoursLogged       Decimal  @db.Decimal(5, 2)
  description       String   @db.Text
  
  approved          Boolean  @default(false)
  approvedAt        DateTime? @db.Timestamptz(3)
  approvedBy        String?  @db.Uuid
  
  billed            Boolean  @default(false)
  billedAt          DateTime? @db.Timestamptz(3)
  billingAmount     Decimal? @db.Decimal(10, 2)
  
  createdAt         DateTime @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime @updatedAt @db.Timestamptz(3)

  contract          Contract        @relation(fields: [contractId], references: [id], onDelete: Cascade)
  engineerProfile   EngineerProfile @relation(fields: [engineerProfileId], references: [id], onDelete: Cascade)

  @@index([contractId])
  @@index([engineerProfileId])
  @@index([date])
  @@index([billed])
  @@map("time_entries")
}

model MilestonePayment {
  id                String          @id @default(uuid()) @db.Uuid
  contractId        String          @db.Uuid
  
  milestoneNumber   Int
  title             String
  description       String          @db.Text
  amount            Decimal         @db.Decimal(12, 2)
  
  status            MilestoneStatus @default(pending)
  
  dueDate           DateTime?       @db.Timestamptz(3)
  submittedAt       DateTime?       @db.Timestamptz(3)
  approvedAt        DateTime?       @db.Timestamptz(3)
  paidAt            DateTime?       @db.Timestamptz(3)
  
  deliverables      Json?           // Array of deliverable items
  submissionNotes   String?         @db.Text
  approvalNotes     String?         @db.Text
  
  escrowId          String?
  payoutId          String?
  
  createdAt         DateTime        @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime        @updatedAt @db.Timestamptz(3)

  contract          Contract        @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
  @@index([status])
  @@map("milestone_payments")
}

model ContractAmendment {
  id                String   @id @default(uuid()) @db.Uuid
  contractId        String   @db.Uuid
  
  amendmentNumber   Int
  reason            String   @db.Text
  changes           Json     // Detailed changes
  
  amendmentPdfUrl   String?
  
  companySigned     Boolean  @default(false)
  companySignedAt   DateTime? @db.Timestamptz(3)
  
  engineerSigned    Boolean  @default(false)
  engineerSignedAt  DateTime? @db.Timestamptz(3)
  
  finalPdfUrl       String?
  
  createdAt         DateTime @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime @updatedAt @db.Timestamptz(3)

  contract          Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
  @@map("contract_amendments")
}

model AvailabilitySlot {
  id                String   @id @default(uuid()) @db.Uuid
  engineerProfileId String   @db.Uuid
  
  startTime         DateTime @db.Timestamptz(3)
  endTime           DateTime @db.Timestamptz(3)
  
  booked            Boolean  @default(false)
  bookedBy          String?  @db.Uuid // Company user ID
  meetingLink       String?
  meetingNotes      String?  @db.Text
  
  createdAt         DateTime @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime @updatedAt @db.Timestamptz(3)

  engineerProfile   EngineerProfile @relation(fields: [engineerProfileId], references: [id], onDelete: Cascade)

  @@index([engineerProfileId])
  @@index([startTime])
  @@index([booked])
  @@map("availability_slots")
}

model MessageRequest {
  id                String               @id @default(uuid()) @db.Uuid
  fromUserId        String               @db.Uuid
  toUserId          String               @db.Uuid
  
  message           String               @db.Text
  status            MessageRequestStatus @default(pending)
  
  respondedAt       DateTime?            @db.Timestamptz(3)
  
  createdAt         DateTime             @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime             @updatedAt @db.Timestamptz(3)

  fromUser          User                 @relation("SentMessageRequests", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser            User                 @relation("ReceivedMessageRequests", fields: [toUserId], references: [id], onDelete: Cascade)

  @@unique([fromUserId, toUserId])
  @@index([toUserId])
  @@index([status])
  @@map("message_requests")
}

model Conversation {
  id                String   @id @default(uuid()) @db.Uuid
  participant1Id    String   @db.Uuid
  participant2Id    String   @db.Uuid
  
  lastMessageAt     DateTime @default(now()) @db.Timestamptz(3)
  
  createdAt         DateTime @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime @updatedAt @db.Timestamptz(3)

  participant1      User     @relation("ConversationsAsParticipant1", fields: [participant1Id], references: [id], onDelete: Cascade)
  participant2      User     @relation("ConversationsAsParticipant2", fields: [participant2Id], references: [id], onDelete: Cascade)
  
  messages          Message[]

  @@unique([participant1Id, participant2Id])
  @@index([participant1Id])
  @@index([participant2Id])
  @@index([lastMessageAt])
  @@map("conversations")
}

model Message {
  id                String   @id @default(uuid()) @db.Uuid
  conversationId    String   @db.Uuid
  senderId          String   @db.Uuid
  
  content           String   @db.Text
  fileUrl           String?
  fileName          String?
  fileSize          Int?
  
  flagged           Boolean  @default(false)
  flagReason        String?  @db.Text
  
  readAt            DateTime? @db.Timestamptz(3)
  
  createdAt         DateTime @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime @updatedAt @db.Timestamptz(3)

  conversation      Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender            User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt])
  @@map("messages")
}

model ProjectChatRoom {
  id                String   @id @default(uuid()) @db.Uuid
  contractId        String   @unique @db.Uuid
  
  name              String
  
  createdAt         DateTime @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime @updatedAt @db.Timestamptz(3)

  contract          Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  
  participants      ProjectChatParticipant[]
  messages          ProjectChatMessage[]

  @@index([contractId])
  @@map("project_chat_rooms")
}

model ProjectChatParticipant {
  id                String   @id @default(uuid()) @db.Uuid
  roomId            String   @db.Uuid
  userId            String   @db.Uuid
  
  role              String   // company_admin, engineer, stakeholder
  
  joinedAt          DateTime @default(now()) @db.Timestamptz(3)

  room              ProjectChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@index([roomId])
  @@index([userId])
  @@map("project_chat_participants")
}

model ProjectChatMessage {
  id                String   @id @default(uuid()) @db.Uuid
  roomId            String   @db.Uuid
  senderId          String   @db.Uuid
  
  content           String   @db.Text
  fileUrl           String?
  fileName          String?
  
  createdAt         DateTime @default(now()) @db.Timestamptz(3)

  room              ProjectChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender            User            @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([roomId])
  @@index([createdAt])
  @@map("project_chat_messages")
}

model OffPlatformViolation {
  id                String                      @id @default(uuid()) @db.Uuid
  userId            String                      @db.Uuid
  
  violationType     String                      // phone, email, whatsapp
  detectedContent   String                      @db.Text
  messageId         String?                     @db.Uuid
  
  level             OffPlatformViolationLevel   @default(warning)
  
  warningIssued     Boolean                     @default(false)
  warningIssuedAt   DateTime?                   @db.Timestamptz(3)
  
  reviewRequired    Boolean                     @default(false)
  reviewedAt        DateTime?                   @db.Timestamptz(3)
  reviewedBy        String?                     @db.Uuid
  
  createdAt         DateTime                    @default(now()) @db.Timestamptz(3)

  user              User                        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([level])
  @@map("off_platform_violations")
}

model EngineerAnalytics {
  id                String   @id @default(uuid()) @db.Uuid
  engineerProfileId String   @db.Uuid
  
  date              DateTime @db.Date
  
  profileViews      Int      @default(0)
  proposalsSent     Int      @default(0)
  proposalsAccepted Int      @default(0)
  earnings          Decimal  @default(0) @db.Decimal(12, 2)
  
  topKeywords       Json?    // Array of search keywords
  topSkills         Json?    // Skills driving views
  
  createdAt         DateTime @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime @updatedAt @db.Timestamptz(3)

  engineerProfile   EngineerProfile @relation(fields: [engineerProfileId], references: [id], onDelete: Cascade)

  @@unique([engineerProfileId, date])
  @@index([engineerProfileId])
  @@index([date])
  @@map("engineer_analytics")
}

model CompanyAnalytics {
  id                String   @id @default(uuid()) @db.Uuid
  companyProfileId  String   @db.Uuid
  
  date              DateTime @db.Date
  
  jobsPosted        Int      @default(0)
  applicationsReceived Int   @default(0)
  hiresMade         Int      @default(0)
  
  avgTimeToHire     Decimal? @db.Decimal(10, 2) // days
  totalSpent        Decimal  @default(0) @db.Decimal(12, 2)
  
  engineerPerformance Json?  // Performance metrics
  marketRateBenchmark Json?  // Rate comparisons
  
  createdAt         DateTime @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime @updatedAt @db.Timestamptz(3)

  companyProfile    CompanyProfile @relation(fields: [companyProfileId], references: [id], onDelete: Cascade)

  @@unique([companyProfileId, date])
  @@index([companyProfileId])
  @@index([date])
  @@map("company_analytics")
}
// Module 7: Payments, Escrow & GST Schema

enum EscrowPaymentType {
  escrow_deposit
  milestone_release
  payout
  subscription
  platform_fee
  refund
}

enum EscrowPaymentStatus {
  pending
  processing
  completed
  failed
  refunded
}

enum PayoutMethod {
  upi
  neft
  imps
}

enum ContractDisputeStatus {
  pending
  under_review
  resolved
  escalated
}

enum KYCStatus {
  not_started
  pending
  verified
  rejected
}

enum SubscriptionTier {
  engineer_basic
  engineer_pro
  engineer_premium
  company_starter
  company_growth
  company_enterprise
}

model Payment {
  id                String        @id @default(uuid()) @db.Uuid
  userId            String        @db.Uuid
  
  type              EscrowPaymentType
  status            EscrowPaymentStatus @default(pending)
  
  amount            Decimal       @db.Decimal(12, 2)
  currency          String        @default("INR")
  
  platformFee       Decimal?      @db.Decimal(12, 2)
  gstAmount         Decimal?      @db.Decimal(12, 2)
  netAmount         Decimal?      @db.Decimal(12, 2)
  
  // Razorpay details
  razorpayOrderId   String?       @unique
  razorpayPaymentId String?       @unique
  razorpaySignature String?
  
  // Reference IDs
  contractId        String?       @db.Uuid
  taskId            String?       @db.Uuid
  milestoneId       String?       @db.Uuid
  productId         String?       @db.Uuid
  purchaseId        String?       @db.Uuid
  
  // Metadata
  description       String?       @db.Text
  metadata          Json?
  
  // Idempotency
  idempotencyKey    String?       @unique
  
  // Timestamps
  processedAt       DateTime?     @db.Timestamptz(3)
  completedAt       DateTime?     @db.Timestamptz(3)
  failedAt          DateTime?     @db.Timestamptz(3)
  failureReason     String?       @db.Text
  
  createdAt         DateTime      @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime      @updatedAt @db.Timestamptz(3)
  
  // Soft delete for 7-year retention
  deletedAt         DateTime?     @db.Timestamptz(3)

  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  invoice           Invoice?
  escrowRelease     EscrowRelease?

  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([contractId])
  @@index([taskId])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("payments")
}

model EscrowAccount {
  id                String   @id @default(uuid()) @db.Uuid
  contractId        String?  @unique @db.Uuid
  taskId            String?  @unique @db.Uuid
  
  totalAmount       Decimal  @db.Decimal(12, 2)
  lockedAmount      Decimal  @db.Decimal(12, 2)
  releasedAmount    Decimal  @default(0) @db.Decimal(12, 2)
  refundedAmount    Decimal  @default(0) @db.Decimal(12, 2)
  
  currency          String   @default("INR")
  
  funded            Boolean  @default(false)
  fundedAt          DateTime? @db.Timestamptz(3)
  
  razorpayAccountId String?
  
  createdAt         DateTime @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime @updatedAt @db.Timestamptz(3)

  releases          EscrowRelease[]

  @@index([contractId])
  @@index([taskId])
  @@index([funded])
  @@map("escrow_accounts")
}

model EscrowRelease {
  id                String   @id @default(uuid()) @db.Uuid
  escrowAccountId   String   @db.Uuid
  paymentId         String   @unique @db.Uuid
  
  amount            Decimal  @db.Decimal(12, 2)
  recipientUserId   String   @db.Uuid
  
  // Release trigger
  triggeredBy       String   // approval, auto_approve, dispute_resolution
  approvedBy        String?  @db.Uuid
  
  // Auto-approve tracking
  autoApproveAt     DateTime? @db.Timestamptz(3)
  autoApproved      Boolean  @default(false)
  
  // Processing
  status            String   @default("pending") // pending, processing, completed, failed
  processedAt       DateTime? @db.Timestamptz(3)
  completedAt       DateTime? @db.Timestamptz(3)
  
  // Idempotency
  idempotencyKey    String   @unique
  
  createdAt         DateTime @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime @updatedAt @db.Timestamptz(3)

  escrowAccount     EscrowAccount @relation(fields: [escrowAccountId], references: [id], onDelete: Cascade)
  payment           Payment       @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([escrowAccountId])
  @@index([status])
  @@index([autoApproveAt])
  @@map("escrow_releases")
}

model Payout {
  id                String       @id @default(uuid()) @db.Uuid
  userId            String       @db.Uuid
  engineerProfileId String       @db.Uuid
  
  amount            Decimal      @db.Decimal(12, 2)
  currency          String       @default("INR")
  
  method            PayoutMethod
  
  // Bank details
  upiId             String?
  accountNumber     String?
  ifscCode          String?
  accountHolderName String?
  
  // Razorpay payout
  razorpayPayoutId  String?      @unique
  razorpayFundAccountId String?
  
  status            String       @default("pending") // pending, processing, completed, failed, reversed
  
  // KYC check
  kycRequired       Boolean      @default(false)
  kycVerified       Boolean      @default(false)
  
  // Processing
  requestedAt       DateTime     @default(now()) @db.Timestamptz(3)
  processedAt       DateTime?    @db.Timestamptz(3)
  completedAt       DateTime?    @db.Timestamptz(3)
  failedAt          DateTime?    @db.Timestamptz(3)
  failureReason     String?      @db.Text
  
  // UTR for NEFT/IMPS
  utr               String?
  
  createdAt         DateTime     @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime     @updatedAt @db.Timestamptz(3)

  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([engineerProfileId])
  @@index([status])
  @@index([requestedAt])
  @@map("payouts")
}

model Wallet {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @unique @db.Uuid
  
  balance           Decimal  @default(0) @db.Decimal(12, 2)
  currency          String   @default("INR")
  
  // Lifetime stats
  totalEarned       Decimal  @default(0) @db.Decimal(12, 2)
  totalWithdrawn    Decimal  @default(0) @db.Decimal(12, 2)
  
  // Monthly withdrawal tracking
  currentMonthWithdrawn Decimal @default(0) @db.Decimal(12, 2)
  lastWithdrawalMonth   String? // YYYY-MM
  
  createdAt         DateTime @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime @updatedAt @db.Timestamptz(3)

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  transactions      WalletTransaction[]

  @@index([userId])
  @@map("wallets")
}

model WalletTransaction {
  id                String   @id @default(uuid()) @db.Uuid
  walletId          String   @db.Uuid
  
  type              String   // credit, debit
  amount            Decimal  @db.Decimal(12, 2)
  
  balanceBefore     Decimal  @db.Decimal(12, 2)
  balanceAfter      Decimal  @db.Decimal(12, 2)
  
  description       String   @db.Text
  
  // Reference
  paymentId         String?  @db.Uuid
  payoutId          String?  @db.Uuid
  
  createdAt         DateTime @default(now()) @db.Timestamptz(3)

  wallet            Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([createdAt])
  @@map("wallet_transactions")
}

model KYCVerification {
  id                String    @id @default(uuid()) @db.Uuid
  userId            String    @db.Uuid
  engineerProfileId String    @db.Uuid
  
  status            KYCStatus @default(not_started)
  
  // Documents
  aadhaarNumber     String?
  aadhaarVerified   Boolean   @default(false)
  aadhaarDocUrl     String?
  
  panNumber         String?
  panVerified       Boolean   @default(false)
  panDocUrl         String?
  
  // Digio verification
  digioRequestId    String?
  digioStatus       String?
  
  // Verification details
  verifiedAt        DateTime? @db.Timestamptz(3)
  verifiedBy        String?   @db.Uuid
  
  rejectedAt        DateTime? @db.Timestamptz(3)
  rejectionReason   String?   @db.Text
  
  createdAt         DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime  @updatedAt @db.Timestamptz(3)

  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
  @@index([engineerProfileId])
  @@index([status])
  @@map("kyc_verifications")
}

model PlatformSubscription {
  id                String           @id @default(uuid()) @db.Uuid
  userId            String           @db.Uuid
  
  tier              SubscriptionTier
  
  // Pricing
  amount            Decimal          @db.Decimal(10, 2)
  currency          String           @default("INR")
  billingCycle      String           // monthly, quarterly, annual
  
  // Razorpay subscription
  razorpaySubscriptionId String?     @unique
  razorpayPlanId    String?
  
  status            String           @default("active") // active, past_due, cancelled, expired
  
  // Billing
  currentPeriodStart DateTime        @db.Timestamptz(3)
  currentPeriodEnd   DateTime        @db.Timestamptz(3)
  nextBillingDate    DateTime?       @db.Timestamptz(3)
  
  // Cancellation
  cancelledAt       DateTime?        @db.Timestamptz(3)
  cancellationReason String?         @db.Text
  cancelAtPeriodEnd Boolean          @default(false)
  
  createdAt         DateTime         @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime         @updatedAt @db.Timestamptz(3)

  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([nextBillingDate])
  @@map("platform_subscriptions")
}

model Invoice {
  id                String   @id @default(uuid()) @db.Uuid
  paymentId         String   @unique @db.Uuid
  
  invoiceNumber     String   @unique
  
  // Parties
  fromName          String
  fromAddress       String?  @db.Text
  fromGstin         String?
  
  toName            String
  toAddress         String?  @db.Text
  toGstin           String?
  
  // Amounts
  subtotal          Decimal  @db.Decimal(12, 2)
  gstRate           Decimal  @db.Decimal(5, 2)
  gstAmount         Decimal  @db.Decimal(12, 2)
  total             Decimal  @db.Decimal(12, 2)
  
  currency          String   @default("INR")
  
  // Line items
  lineItems         Json     // Array of items
  
  // Invoice details
  invoiceDate       DateTime @db.Timestamptz(3)
  dueDate           DateTime? @db.Timestamptz(3)
  
  // PDF
  pdfUrl            String?
  
  // ClearTax integration
  clearTaxId        String?
  clearTaxStatus    String?
  
  // Email
  emailSent         Boolean  @default(false)
  emailSentAt       DateTime? @db.Timestamptz(3)
  
  createdAt         DateTime @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime @updatedAt @db.Timestamptz(3)
  
  // Soft delete for 7-year retention
  deletedAt         DateTime? @db.Timestamptz(3)

  payment           Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([invoiceNumber])
  @@index([invoiceDate])
  @@index([deletedAt])
  @@map("invoices")
}

model ContractDispute {
  id                String        @id @default(uuid()) @db.Uuid
  contractId        String        @db.Uuid
  
  raisedBy          String        @db.Uuid // User ID
  againstUserId     String        @db.Uuid
  
  reason            String        @db.Text
  description       String        @db.Text
  
  // Evidence
  evidence          Json?         // Array of evidence items
  
  status            ContractDisputeStatus @default(pending)
  
  // AI audit
  aiAuditSummary    String?       @db.Text
  aiRecommendation  Json?         // Recommended split, reasoning
  
  // Resolution
  resolvedBy        String?       @db.Uuid
  resolution        String?       @db.Text
  
  // Partial release
  engineerAmount    Decimal?      @db.Decimal(12, 2)
  companyRefund     Decimal?      @db.Decimal(12, 2)
  
  // Timestamps
  raisedAt          DateTime      @default(now()) @db.Timestamptz(3)
  reviewStartedAt   DateTime?     @db.Timestamptz(3)
  resolvedAt        DateTime?     @db.Timestamptz(3)
  
  // Deadlines
  reviewDeadline    DateTime      @db.Timestamptz(3)
  
  createdAt         DateTime      @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime      @updatedAt @db.Timestamptz(3)

  contract          Contract      @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
  @@index([status])
  @@index([raisedBy])
  @@map("contract_disputes")
}

model WebhookEvent {
  id                String   @id @default(uuid()) @db.Uuid
  
  provider          String   // razorpay, cleartax, digio
  eventType         String
  
  payload           Json
  signature         String?
  
  verified          Boolean  @default(false)
  processed         Boolean  @default(false)
  
  // Idempotency
  idempotencyKey    String   @unique
  
  processedAt       DateTime? @db.Timestamptz(3)
  failedAt          DateTime? @db.Timestamptz(3)
  failureReason     String?  @db.Text
  
  retryCount        Int      @default(0)
  
  createdAt         DateTime @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime @updatedAt @db.Timestamptz(3)

  @@index([provider])
  @@index([eventType])
  @@index([processed])
  @@index([createdAt])
  @@map("webhook_events")
}

// Module 8: Security, Compliance & Monitoring Schema

enum ConsentType {
  marketing_email
  profile_recommendations
  webcam_proctoring
  public_activity
}

enum DeletionStatus {
  pending
  completed
  cancelled
}

model UserConsent {
  id            String      @id @default(uuid()) @db.Uuid
  userId        String      @db.Uuid
  
  consentType   ConsentType
  granted       Boolean
  
  ipAddress     String
  userAgent     String
  
  timestamp     DateTime    @default(now()) @db.Timestamptz(3)

  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([consentType])
  @@map("user_consents")
}

model AccountDeletionRequest {
  id            String         @id @default(uuid()) @db.Uuid
  userId        String         @db.Uuid
  
  reason        String?        @db.Text
  
  requestedAt   DateTime       @default(now()) @db.Timestamptz(3)
  scheduledFor  DateTime       @db.Timestamptz(3)
  processedAt   DateTime?      @db.Timestamptz(3)
  
  status        DeletionStatus @default(pending)
  
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([scheduledFor])
  @@map("account_deletion_requests")
}

model PrivacyPolicyAcceptance {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @db.Uuid
  
  version       String
  
  ipAddress     String
  userAgent     String
  
  acceptedAt    DateTime @default(now()) @db.Timestamptz(3)

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([version])
  @@map("privacy_policy_acceptances")
}

model SecurityLog {
  id            String   @id @default(uuid()) @db.Uuid
  
  event         String   // failed_login, suspicious_activity, admin_action, etc.
  userId        String?  @db.Uuid
  
  ip            String
  userAgent     String?
  
  details       Json?
  
  timestamp     DateTime @default(now()) @db.Timestamptz(3)

  @@index([event])
  @@index([userId])
  @@index([timestamp])
  @@map("security_logs")
}

model AuditLog {
  id            String   @id @default(uuid()) @db.Uuid
  
  action        String   // create, update, delete
  entity        String   // user, task, contract, payment, etc.
  entityId      String   @db.Uuid
  
  userId        String?  @db.Uuid
  
  before        Json?    // State before change
  after         Json?    // State after change
  
  ip            String
  userAgent     String?
  
  timestamp     DateTime @default(now()) @db.Timestamptz(3)

  @@index([entity])
  @@index([entityId])
  @@index([userId])
  @@index([timestamp])
  @@map("audit_logs")
}

model HealthCheck {
  id            String   @id @default(uuid()) @db.Uuid
  
  service       String   // api, database, redis, s3, etc.
  status        String   // healthy, degraded, down
  
  responseTime  Int?     // in milliseconds
  errorMessage  String?  @db.Text
  
  timestamp     DateTime @default(now()) @db.Timestamptz(3)

  @@index([service])
  @@index([status])
  @@index([timestamp])
  @@map("health_checks")
}
