// Module 5: AI Marketplace Models

enum ProductCategory {
  ai_agents
  fine_tuned_models
  saas_tools
  automation_workflows
  datasets_prompts
  apis_microservices
}

enum PricingModel {
  one_time
  subscription
  freemium
  per_call
}

enum ProductStatus {
  draft
  pending_moderation
  published
  suspended
  archived
}

enum PurchaseStatus {
  pending
  completed
  failed
  refunded
  disputed
}

enum DisputeStatus {
  open
  under_review
  resolved_buyer
  resolved_seller
  closed
}

enum SubscriptionStatus {
  active
  past_due
  cancelled
  expired
}

model Product {
  id                String          @id @default(uuid()) @db.Uuid
  engineerProfileId String          @db.Uuid
  userId            String          @db.Uuid
  
  // Basic info
  name              String
  slug              String          @unique
  tagline           String
  category          ProductCategory
  tags              String[]
  thumbnailUrl      String
  description       String          @db.Text
  demoUrl           String
  screenshots       String[]        // Min 3, S3 URLs
  
  // Technical details
  techStack         Json            // Array of technologies
  aiModelUsed       String?
  architectureType  String?
  
  // Pricing
  pricingModel      PricingModel
  priceINR          Decimal?        @db.Decimal(12, 2)
  priceUSD          Decimal?        @db.Decimal(12, 2)
  features          Json            // Array of feature objects
  
  // Performance & delivery
  performanceMetrics Json?
  deliveryType      String          // instant, 24h, 48h, custom
  customizationAvailable Boolean    @default(false)
  supportType       String?         // email, chat, phone
  supportDuration   String?         // 30days, 90days, 1year, lifetime
  
  // Versioning
  currentVersion    String          @default("1.0.0")
  versionHistory    Json?           // Array of version objects
  
  // Status & moderation
  status            ProductStatus   @default(draft)
  moderationStatus  String?         // approved, rejected, pending
  moderationNotes   String?         @db.Text
  moderatedAt       DateTime?       @db.Timestamptz(3)
  
  // Stats
  viewCount         Int             @default(0)
  purchaseCount     Int             @default(0)
  rating            Decimal?        @db.Decimal(3, 2)
  reviewCount       Int             @default(0)
  
  // Metadata
  publishedAt       DateTime?       @db.Timestamptz(3)
  createdAt         DateTime        @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime        @updatedAt @db.Timestamptz(3)

  engineerProfile   EngineerProfile @relation(fields: [engineerProfileId], references: [id], onDelete: Cascade)
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  purchases         Purchase[]
  reviews           ProductReview[]
  bundles           BundleProduct[]
  analytics         ProductAnalytics[]

  @@index([engineerProfileId])
  @@index([userId])
  @@index([category])
  @@index([status])
  @@index([slug])
  @@index([publishedAt])
  @@index([rating])
  @@map("products")
}

model Purchase {
  id                String         @id @default(uuid()) @db.Uuid
  productId         String         @db.Uuid
  buyerId           String         @db.Uuid // User ID
  companyProfileId  String?        @db.Uuid
  
  // Purchase details
  priceINR          Decimal        @db.Decimal(12, 2)
  priceUSD          Decimal?       @db.Decimal(12, 2)
  currency          String         @default("INR")
  
  // Payment
  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpaySignature String?
  paymentMethod     String?        // upi, card, netbanking
  
  // License
  licenseKey        String         @unique
  licenseActive     Boolean        @default(true)
  licenseRevokedAt  DateTime?      @db.Timestamptz(3)
  
  // Access
  accessGranted     Boolean        @default(false)
  accessDetails     Json?          // Download links, API keys, etc.
  
  // Status
  status            PurchaseStatus @default(pending)
  
  // Payout
  platformCommission Decimal?      @db.Decimal(12, 2)
  engineerPayout    Decimal?       @db.Decimal(12, 2)
  payoutStatus      String?        // pending, processing, completed, failed
  payoutId          String?        // Razorpay payout ID
  paidOutAt         DateTime?      @db.Timestamptz(3)
  
  // Referral
  referralCode      String?
  referralCommission Decimal?      @db.Decimal(12, 2)
  
  // Dispute
  disputeEligible   Boolean        @default(true)
  disputeDeadline   DateTime       @db.Timestamptz(3) // 30 days from purchase
  
  purchasedAt       DateTime       @default(now()) @db.Timestamptz(3)
  createdAt         DateTime       @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime       @updatedAt @db.Timestamptz(3)

  product           Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  buyer             User           @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  companyProfile    CompanyProfile? @relation(fields: [companyProfileId], references: [id], onDelete: SetNull)
  
  dispute           Dispute?
  subscription      Subscription?

  @@index([productId])
  @@index([buyerId])
  @@index([companyProfileId])
  @@index([licenseKey])
  @@index([status])
  @@index([referralCode])
  @@map("purchases")
}

model Subscription {
  id                String             @id @default(uuid()) @db.Uuid
  purchaseId        String             @unique @db.Uuid
  productId         String             @db.Uuid
  buyerId           String             @db.Uuid
  
  // Razorpay subscription
  razorpaySubscriptionId String?       @unique
  razorpayPlanId    String?
  
  // Billing
  billingCycle      String             // monthly, quarterly, yearly
  nextBillingDate   DateTime           @db.Timestamptz(3)
  lastBillingDate   DateTime?          @db.Timestamptz(3)
  
  // Status
  status            SubscriptionStatus @default(active)
  failedPayments    Int                @default(0)
  
  // Cancellation
  cancelledAt       DateTime?          @db.Timestamptz(3)
  cancellationReason String?           @db.Text
  
  createdAt         DateTime           @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime           @updatedAt @db.Timestamptz(3)

  purchase          Purchase           @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([buyerId])
  @@index([status])
  @@index([nextBillingDate])
  @@map("subscriptions")
}

model Dispute {
  id                String         @id @default(uuid()) @db.Uuid
  purchaseId        String         @unique @db.Uuid
  productId         String         @db.Uuid
  buyerId           String         @db.Uuid
  sellerId          String         @db.Uuid
  
  // Dispute details
  reason            String         @db.Text
  evidence          Json?          // Screenshots, logs, etc.
  
  // Status
  status            DisputeStatus  @default(open)
  resolution        String?        @db.Text
  resolvedBy        String?        @db.Uuid // Admin user ID
  resolvedAt        DateTime?      @db.Timestamptz(3)
  
  // Refund
  refundAmount      Decimal?       @db.Decimal(12, 2)
  refundProcessed   Boolean        @default(false)
  refundId          String?
  
  createdAt         DateTime       @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime       @updatedAt @db.Timestamptz(3)

  purchase          Purchase       @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
  @@map("disputes")
}

model ProductReview {
  id                String   @id @default(uuid()) @db.Uuid
  productId         String   @db.Uuid
  purchaseId        String   @db.Uuid
  buyerId           String   @db.Uuid
  
  // Review
  rating            Int      // 1-5
  title             String?
  review            String   @db.Text
  pros              String[] // Array of pros
  cons              String[] // Array of cons
  
  // Verification
  verified          Boolean  @default(true) // Verified purchase
  
  // Helpful votes
  helpfulCount      Int      @default(0)
  
  createdAt         DateTime @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime @updatedAt @db.Timestamptz(3)

  product           Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([purchaseId]) // One review per purchase
  @@index([productId])
  @@index([buyerId])
  @@index([rating])
  @@map("product_reviews")
}

model Bundle {
  id                String          @id @default(uuid()) @db.Uuid
  engineerProfileId String          @db.Uuid
  userId            String          @db.Uuid
  
  name              String
  description       String          @db.Text
  thumbnailUrl      String?
  
  // Pricing
  originalPrice     Decimal         @db.Decimal(12, 2)
  bundlePrice       Decimal         @db.Decimal(12, 2)
  discountPercent   Decimal         @db.Decimal(5, 2)
  currency          String          @default("INR")
  
  // Status
  active            Boolean         @default(true)
  
  createdAt         DateTime        @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime        @updatedAt @db.Timestamptz(3)

  products          BundleProduct[]

  @@index([engineerProfileId])
  @@index([userId])
  @@index([active])
  @@map("bundles")
}

model BundleProduct {
  id                String   @id @default(uuid()) @db.Uuid
  bundleId          String   @db.Uuid
  productId         String   @db.Uuid
  
  displayOrder      Int      @default(0)
  
  createdAt         DateTime @default(now()) @db.Timestamptz(3)

  bundle            Bundle   @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  product           Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([bundleId, productId])
  @@index([bundleId])
  @@index([productId])
  @@map("bundle_products")
}

model ReferralLink {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @db.Uuid
  productId         String?  @db.Uuid // Null for general referral
  
  referralCode      String   @unique
  
  // Stats
  clickCount        Int      @default(0)
  purchaseCount     Int      @default(0)
  totalCommission   Decimal  @default(0) @db.Decimal(12, 2)
  
  active            Boolean  @default(true)
  
  createdAt         DateTime @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime @updatedAt @db.Timestamptz(3)

  @@index([userId])
  @@index([productId])
  @@index([referralCode])
  @@map("referral_links")
}

model ProductAnalytics {
  id                String   @id @default(uuid()) @db.Uuid
  productId         String   @db.Uuid
  
  // Date
  date              DateTime @db.Date
  
  // Metrics
  views             Int      @default(0)
  purchases         Int      @default(0)
  revenue           Decimal  @default(0) @db.Decimal(12, 2)
  refunds           Int      @default(0)
  
  // Buyer industries (top 5)
  topIndustries     Json?
  
  createdAt         DateTime @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime @updatedAt @db.Timestamptz(3)

  product           Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, date])
  @@index([productId])
  @@index([date])
  @@map("product_analytics")
}

