{
  "name": "@neuronhire/api",
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest --runInBand",
    "test:watch": "jest --watch --runInBand",
    "test:integration": "jest --testPathPattern=integration --runInBand",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "clean": "rm -rf dist",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:check": "tsx scripts/check-db-tables.ts",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "worker": "tsx src/workers/assessment-worker.ts",
    "worker:task": "tsx src/workers/task-enrichment-worker.ts",
    "seed:questions": "tsx src/scripts/seed-questions.ts",
    "seed": "tsx prisma/seed.ts",
    "seed:fresh": "tsx prisma/seed.ts --fresh"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.94.0",
    "@aws-sdk/client-s3": "^3.1042.0",
    "@clerk/backend": "^1.13.8",
    "@clerk/fastify": "^1.0.0",
    "@fastify/cookie": "^9.2.0",
    "@fastify/cors": "^8.5.0",
    "@fastify/csrf-protection": "^6.4.0",
    "@fastify/helmet": "^11.1.1",
    "@fastify/multipart": "^8.0.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/websocket": "^9.0.0",
    "@neuronhire/shared": "*",
    "@prisma/client": "^5.22.0",
    "@types/pdfkit": "^0.13.3",
    "aws-sdk": "^2.1515.0",
    "bullmq": "^5.1.0",
    "dotenv": "^16.3.1",
    "fastify": "^4.25.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.3.0",
    "openai": "^4.20.0",
    "pdfkit": "^0.14.0",
    "pg": "^8.20.0",
    "razorpay": "^2.9.2",
    "socket.io": "^4.6.0",
    "typesense": "^1.7.2",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/body-parser": "^1.19.5",
    "@types/express": "^4.17.21",
    "@types/express-serve-static-core": "^4.17.41",
    "@types/http-errors": "^2.0.4",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.0",
    "@types/qs": "^6.9.10",
    "@types/range-parser": "^1.2.7",
    "@types/send": "^0.17.4",
    "@types/serve-static": "^1.15.5",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "prettier": "^3.8.3",
    "prisma": "^5.22.0",
    "ts-jest": "^29.1.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
