# Copy to .env.local (overrides .env) for local development.
# cp .env.local.example .env.local

# Supabase: SESSION pooler on port 5432 (required for Prisma — port 6543 breaks queries)
# DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# PostgreSQL — local install or Docker (if you have Docker)
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/neuronhire"

# In-memory Redis (no Docker required)
REDIS_URL="memory://"

# Skip cloud MongoDB / Typesense when they fail locally (recommended on Windows dev)
SKIP_MONGODB=true
SKIP_TYPESENSE=true

# Or use local MongoDB instead of Atlas:
# SKIP_MONGODB=false
# MONGODB_URL="mongodb://127.0.0.1:27017/neuronhire"

# Or use Typesense Cloud (full hostname, not cluster id alone):
# SKIP_TYPESENSE=false
# TYPESENSE_HOST="xxx.a1.typesense.net"
# TYPESENSE_PORT="443"
# TYPESENSE_PROTOCOL="https"
# TYPESENSE_API_KEY="your-key"
